# Slim Voice Feature Extraction Pipeline

# HuggingFace Token (required for MERaLiON-SER-v1 gated model)
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# ── Device Configuration ──
# Options: auto, cpu, cuda, cuda:0, cuda:1, mps
EMOTION_DEVICE=auto

# ── GPU Assignment (when using CUDA) ──
EMOTION_GPU=0

# ── Batch Processing ──
# 0 = auto-detect based on GPU memory
EMOTION_BATCH_SIZE=0

# ── Language Profile ──
# Options: non_native_english, native_english, sea_english
LANGUAGE_PROFILE=non_native_english

# ── Model Cache (set to persistent dir to avoid re-downloads) ──
# HF_HOME=/models

# ── Output ──
OUTPUT_DIR=./outputs
